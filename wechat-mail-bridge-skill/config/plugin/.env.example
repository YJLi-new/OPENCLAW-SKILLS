HOST=0.0.0.0
PORT=8787

BRIDGE_SHARED_SECRET=dev-bridge-secret
AUTH_WINDOW_SEC=300
SQLITE_PATH=./state/wechat-mail-bridge.db
SWEEP_INTERVAL_SEC=5
STALE_CLAIM_SEC=120
DEDUPE_RETENTION_HOURS=72
JOB_RETENTION_HOURS=168
SIDECAR_STALE_SEC=60

ALLOW_GROUPS=Ops Group,Mail Group
TRIGGER_PREFIXES=/mail,查邮箱,/watch,/mail-watch,监控
PASSIVE_SINGLE_EMAIL_MODE=false
DEFAULT_WAIT_TIMEOUT_SEC=120

MAIL_BACKEND=mock
MAIL_QUERY_MODE=direct-api
MAIL_PREFER_PUSH_WEBHOOK=true
BHMAILER_API_BASE=https://bsh.bhdata.com:30015
BHMAILER_UID=
BHMAILER_SIGN=
BHMAILER_WEBHOOK_SECRET=
BHMAILER_DEFAULT_TIMEOUT_SEC=20
BHMAILER_EXTRACTION_PROFILE=default

REPLY_MAX_BODY_PREVIEW_CHARS=400
REPLY_INCLUDE_SUBJECT=true
REPLY_INCLUDE_FROM=true
REPLY_INCLUDE_RECEIVED_AT=true

PRIVACY_REDACT_EMAILS_IN_LOGS=true
PRIVACY_STORE_RAW_WECHAT_TEXT=true
PRIVACY_STORE_RAW_MAIL_BODY=false
